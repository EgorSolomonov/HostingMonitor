# --- PHP ---
vendor/                    # Зависимости Composer
composer.lock              # Локи

# --- Логи и кэш ---
*.log                      # Лог-файлы
logs/                      # Папка логов
cache/                     # Кэш
tmp/                       # Временные файлы

# --- Xdebug ---
xdebug.log                 # Лог отладки
*.xdebug                   # Файлы xdebug

# --- Docker ---
.dockerdata/               # Данные контейнеров (БД, volume)
*.env                      # Переменные окружения
.env.local                 # Локальные настройки

# --- IDE ---
.idea/                     # PhpStorm
.vscode/                   # VS Code
*.swp                      # Vim swap files

# --- OS ---
.DS_Store                  # macOS
Thumbs.db                  # Windows